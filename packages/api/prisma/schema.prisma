// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
    provider = "prisma-client-js"
    output   = "../src/generated/client"
}

datasource db {
    provider = "postgresql"
}

enum MemberCategory {
    Pleno
    Cadete
    Honorario
}

enum MemberStatus {
    Activo
    Moroso
    Suspendido
}

model Member {
    id         String         @id @default(uuid())
    dni        String         @unique
    name       String
    email      String         @unique
    birthdate  DateTime?      @db.Date
    category   MemberCategory
    status     MemberStatus   @default(Activo)
    created_at DateTime       @default(now())
    lockers    Locker[]

    payments Payment[]

    @@map("members") // Para que en la DB la tabla se llame 'members' en minúscula
}

enum LockerStatus {
    Available
    Occupied
    Maintenance
}

model Locker {
    id        String       @id @default(uuid())
    number    Int          @unique
    location  String
    status    LockerStatus @default(Available)
    member_id String?
    member    Member?      @relation(fields: [member_id], references: [id])
    sport     Sport?       @relation(fields: [sportId], references: [id])
    sportId   String?

    @@map("lockers")
}

enum PaymentStatus {
    Pending
    Paid
    Canceled
}

model Payment {
    id           String        @id @default(uuid())
    amount       Float
    month        Int
    year         Int
    status       PaymentStatus @default(Pending)
    due_date     DateTime      @db.Date
    payment_date DateTime?
    deleted_at   DateTime?
    member_id    String
    member       Member        @relation(fields: [member_id], references: [id])
    sport        Sport?        @relation(fields: [sportId], references: [id])
    sportId      String?

    @@map("payments")
}

model Sport {
    id                           String    @id @default(uuid())
    name                         String // No es unique porque tiene que poder dar de alta un nombre repetido siempre que deleted_at no sea nulo.
    description                  String? // Equivale a string | nill
    max_capacity                 Int
    additional_price             Float     @default(0)
    requires_medical_certificate Boolean
    created_at                   DateTime  @default(now())
    deleted_at                   DateTime?
    lockers                      Locker[]
    payments                     Payment[]

    @@map("sport")
}
